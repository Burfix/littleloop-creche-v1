rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userData().role;
    }

    function userSchoolId() {
      return userData().schoolId;
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }

    function isOwnerOf(schoolId) {
      return isSignedIn() && userRole() == 'owner' && userSchoolId() == schoolId;
    }

    function isTeacherOf(schoolId) {
      return isSignedIn() && userRole() == 'teacher' && userSchoolId() == schoolId;
    }

    // ── Users ────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId)
      );
      allow create: if isSuperAdmin();
      // Users can update their own non-sensitive fields; superadmin can update anything
      allow update: if isSignedIn() && (
        (request.auth.uid == uid &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'schoolId', 'branchId'])) ||
        isSuperAdmin()
      );
    }

    // ── Schools ──────────────────────────────────────────────────
    match /schools/{schoolId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(schoolId) ||
        isTeacherOf(schoolId) ||
        userSchoolId() == schoolId
      );
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isOwnerOf(schoolId);
      allow delete: if isSuperAdmin();
    }

    // ── Children ─────────────────────────────────────────────────
    match /children/{childId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        isTeacherOf(resource.data.schoolId) ||
        (userRole() == 'parent' && request.auth.uid in resource.data.parentIds)
      );
      allow create: if isOwnerOf(request.resource.data.schoolId) || isSuperAdmin();
      allow update: if isOwnerOf(resource.data.schoolId) || isSuperAdmin() ||
        isTeacherOf(resource.data.schoolId);
      allow delete: if isOwnerOf(resource.data.schoolId) || isSuperAdmin();
    }

    // ── Classes ──────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        userSchoolId() == resource.data.schoolId
      );
      allow write: if isOwnerOf(resource.data.schoolId) || isSuperAdmin();
    }

    // ── Daily Updates ────────────────────────────────────────────
    match /daily_updates/{updateId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        isTeacherOf(resource.data.schoolId) ||
        (userRole() == 'parent' && request.auth.uid in
          get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parentIds)
      );
      allow create, update: if isTeacherOf(request.resource.data.schoolId) ||
        isOwnerOf(request.resource.data.schoolId) || isSuperAdmin();
    }

    // ── Moments ──────────────────────────────────────────────────
    match /moments/{momentId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        isTeacherOf(resource.data.schoolId) ||
        (userRole() == 'parent' && resource.data.visibleToParents &&
          request.auth.uid in
            get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parentIds)
      );
      allow create: if isTeacherOf(request.resource.data.schoolId) || isSuperAdmin();
      allow update: if isTeacherOf(resource.data.schoolId) ||
        isOwnerOf(resource.data.schoolId) || isSuperAdmin();
      allow delete: if isOwnerOf(resource.data.schoolId) || isSuperAdmin();
    }

    // ── Invoices ─────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        (userRole() == 'parent' && resource.data.parentId == request.auth.uid)
      );
      allow create: if isOwnerOf(request.resource.data.schoolId) || isSuperAdmin();
      allow update: if isOwnerOf(resource.data.schoolId) || isSuperAdmin() ||
        // Parents can only upload proof — no other field changes allowed
        (userRole() == 'parent' &&
          resource.data.parentId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['proofUrl']));
      allow delete: if isOwnerOf(resource.data.schoolId) || isSuperAdmin();
    }

    // ── Tasks ────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        isTeacherOf(resource.data.schoolId)
      );
      allow create, update: if isTeacherOf(request.resource.data.schoolId) ||
        isOwnerOf(request.resource.data.schoolId) || isSuperAdmin();
      allow delete: if isOwnerOf(resource.data.schoolId) || isSuperAdmin();
    }

    // ── Messages ─────────────────────────────────────────────────
    // threadId format: {teacherId}_{parentId}_{childId}
    // Only the two participants in the thread can read it.
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        // Sender can always read their own messages
        resource.data.senderId == request.auth.uid ||
        // Thread participant check: uid appears anywhere in the threadId segments
        request.auth.uid in resource.data.threadId.split('_')
      );
      allow create: if isSignedIn() &&
        // Sender must be themselves
        request.resource.data.senderId == request.auth.uid &&
        // Must be a participant in the thread they're writing to
        request.auth.uid in request.resource.data.threadId.split('_') &&
        // Must belong to the school
        userSchoolId() == request.resource.data.schoolId;
    }

    // ── Admissions ───────────────────────────────────────────────
    // Public create (no auth required — anyone can apply)
    // Only owners and superadmins can read/update
    match /admissions/{admissionId} {
      allow create: if true; // public application form
      allow read, update: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId)
      );
      allow delete: if isSuperAdmin();
    }

    // ── Learning Journals ─────────────────────────────────────────
    match /journal_entries/{entryId} {
      // Parents see only entries shared with them, for their own child
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        isTeacherOf(resource.data.schoolId) ||
        (resource.data.sharedWithParent == true &&
          request.auth.uid in get(/databases/$(database)/documents/children/$(resource.data.childId)).data.parentIds)
      );
      // Only staff write
      allow create: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(request.resource.data.schoolId) ||
        isTeacherOf(request.resource.data.schoolId)
      );
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        isTeacherOf(resource.data.schoolId)
      );
      allow delete: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        resource.data.authorId == request.auth.uid
      );
    }

    // ── HR Profiles ───────────────────────────────────────────────
    match /hr_profiles/{staffUid} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        request.auth.uid == staffUid
      );
      allow write: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(request.resource.data.schoolId)
      );
    }

    // ── Leave Requests ────────────────────────────────────────────
    match /leave_requests/{requestId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        request.auth.uid == resource.data.staffUid
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.staffUid;
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId)
      );
      allow delete: if isSuperAdmin() || isOwnerOf(resource.data.schoolId);
    }

    // ── Waiting List ──────────────────────────────────────────────
    // Public create, owner read/update only
    match /waitlist/{entryId} {
      allow create: if true;
      allow read, update: if isSignedIn() && (
        isSuperAdmin() || isOwnerOf(resource.data.schoolId)
      );
      allow delete: if isSuperAdmin() || isOwnerOf(resource.data.schoolId);
    }

    // ── Medical Records ───────────────────────────────────────────
    match /medical_records/{childId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(resource.data.schoolId) ||
        isTeacherOf(resource.data.schoolId) ||
        (request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.parentIds)
      );
      allow create, update: if isSignedIn() && (
        isSuperAdmin() ||
        isOwnerOf(request.resource.data.schoolId) ||
        isTeacherOf(request.resource.data.schoolId)
      );
      allow delete: if isSuperAdmin();
    }

    // ── FCM Tokens ────────────────────────────────────────────────
    match /fcm_tokens/{tokenId} {
      allow create, update: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
      allow read: if false;
    }
  }
}
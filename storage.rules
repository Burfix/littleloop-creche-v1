rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function userData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function invoiceData(invoiceId) {
      return firestore.get(/databases/(default)/documents/invoices/$(invoiceId)).data;
    }

    // School moment photos
    match /schools/{schoolId}/moments/{fileName} {
      // Only users who belong to this school can read moment photos.
      // Superadmins are cross-school and bypass the schoolId check.
      allow read: if request.auth != null && (
        userData().schoolId == schoolId ||
        userData().role == 'superadmin'
      );
      allow write: if request.auth != null &&
        userData().schoolId == schoolId &&
        userData().role in ['teacher', 'owner', 'superadmin'] &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB max
        request.resource.contentType.matches('image/.*');
    }

    // Payment proof uploads
    match /schools/{schoolId}/proofs/{invoiceId}/{fileName} {
      allow read: if request.auth != null &&
        invoiceData(invoiceId).schoolId == schoolId &&
        (
          invoiceData(invoiceId).parentId == request.auth.uid ||
          userData().role in ['owner', 'superadmin']
        );
      allow create: if request.auth != null &&
        invoiceData(invoiceId).schoolId == schoolId &&
        invoiceData(invoiceId).parentId == request.auth.uid &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('(image/.*|application/pdf)');
    }

    // School logos (owner/superadmin only)
    match /schools/{schoolId}/logo/{fileName} {
      allow read: if true; // Public
      allow write: if request.auth != null &&
        userData().role in ['owner', 'superadmin'];
    }

    // School Launch data import uploads (enrolment/teacher/parent lists,
    // fee structure) — owner uploads, LittleLoop staff review and import
    // by hand. See firestore.rules launchUploads for the matching doc.
    match /schools/{schoolId}/launch-uploads/{fileName} {
      allow read: if request.auth != null && (
        userData().role == 'superadmin' ||
        (userData().schoolId == schoolId && userData().role == 'owner')
      );
      allow write: if request.auth != null &&
        userData().schoolId == schoolId &&
        userData().role == 'owner' &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB max
        request.resource.contentType.matches('(text/csv|application/vnd\\.ms-excel|application/vnd\\.openxmlformats-officedocument\\.spreadsheetml\\.sheet|application/octet-stream|text/plain)');
    }
  }
}

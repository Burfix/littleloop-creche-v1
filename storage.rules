rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // School moment photos
    match /schools/{schoolId}/moments/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'owner', 'superadmin'] &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB max
        request.resource.contentType.matches('image/.*');
    }

    // Payment proof uploads
    match /schools/{schoolId}/proofs/{fileName} {
      allow read: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId &&
        request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    // School logos (owner/superadmin only)
    match /schools/{schoolId}/logo/{fileName} {
      allow read: if true; // Public
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['owner', 'superadmin'];
    }
  }
}
